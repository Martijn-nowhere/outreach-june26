# ============================================================
# Dutch B2B Outreach Pipeline - Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- Required: Anthropic Claude API ---
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Optional: Hunter.io for email finding ---
# Get your key at: https://hunter.io/api
# Leave empty to use pattern-based email guessing only
HUNTER_API_KEY=

# --- Gmail OAuth (for creating draft emails) ---
# Run setup_gmail.py to generate credentials.json
# Then set the path here (relative to project root)
GMAIL_CREDENTIALS_PATH=credentials.json

# --- Outreach language ---
# "nl" for Dutch, "en" for English
OUTREACH_LANGUAGE=nl

# --- Your sender identity ---
YOUR_NAME=Anne
YOUR_COMPANY=YourCompany
YOUR_PRODUCT_DESCRIPTION=Educational platform helping companies achieve their sustainability goals through employee education programs

# --- Pipeline settings ---
# Minimum relevance score (1-10) to include a company in contact finding
RELEVANCE_THRESHOLD=6
