# ============================================================
# School of Recycling — Dutch B2B Outreach Pipeline
# Copy this file to .env and fill in your values
# ============================================================

# --- Required: Anthropic Claude API ---
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Optional: Hunter.io for email finding ---
# Free tier = 25 lookups/month — https://hunter.io/api
# Leave empty to use pattern-based email guessing only
HUNTER_API_KEY=

# --- Gmail OAuth (for creating draft emails) ---
# Run: python setup_gmail.py  to generate credentials.json
GMAIL_CREDENTIALS_PATH=credentials.json

# --- Outreach language ---
# "nl" for Dutch, "en" for English
OUTREACH_LANGUAGE=nl

# --- Your sender identity ---
YOUR_NAME=Martijn
YOUR_COMPANY=School of Recycling
YOUR_PRODUCT_DESCRIPTION=Digital waste literacy platform — employees learn how plastic, recycling and waste systems actually work. Online courses for CSR/ESG teams and employee education programmes. schoolofrecycling.com

# --- Pipeline settings ---
# Minimum CSR relevance score (1-10) to pursue a company
# Raise to 7-8 to focus only on companies strongly mentioning plastic/waste/education
RELEVANCE_THRESHOLD=4

# --- LinkedIn daily queue ---
# How many LinkedIn connection requests to send per day (stay under 10 to be safe)
LINKEDIN_DAILY_LIMIT=5
